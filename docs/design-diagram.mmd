flowchart TD
  LA[LaunchAgent\nlogin autostart] --> GUI[performance_gui.py]

  subgraph APP[performance_gui.py Runtime]
    BE[BotEngine\n1 s tick]
    HTTP[HTTP Handler\n127.0.0.1:8765]

    subgraph STORE[SQLite — 90-day Disk Cache]
      DM[(metrics\n1 row per 10 s)]
      DRO[(remediation_outcomes)]
      DSW[(signal_weights)]
    end

    BE -->|snapshot| HTTP
    BE -->|cache.record + flush| DM
    DM -->|aggregates| BE
  end

  subgraph OS[macOS Signals and Metrics]
    PS[psutil.process_iter\n1 scan per second]
    SYS[sysctl\nkern.memorystatus — 5 s]
    VM[vm_stat\n5 s]
    PM[pmset thermal / power\n30–60 s]
  end

  PS --> BE
  SYS --> BE
  VM --> BE
  PM --> BE

  subgraph L1[Signal Processing Layer]
    SIE[SIE — Signal Integrity Estimator\nz-score anomaly confidence per signal]
    MEG[MEG — Model Ensemble Governance\nmeta-weight historical residuals over MMAF models]
  end

  subgraph L2[Forecasting and Pressure]
    MMAF[MMAF — Multi-Model Adaptive Forecaster\nlinear + quadratic + exponential\nbest-RSS model wins — TTE to 95%]
    CEO[CEO — Compression Efficiency Oracle\nCPI = compressed / compressed+purgeable]
    TMCP[TMCP — Thermal-Memory Coupling Predictor\nEMA-learned thermal coeff — shortens TTE under throttle]
    AIP[AIP — Ancestral Impact Propagation\nrecursive RSS depth scoring — cascade risk detection]
  end

  subgraph L3[Tier Decision Layer]
    ACN[ACN / MSCEE — Adaptive Consensus Network\n6-signal RWA-weighted quorum — effective tier 0–4\nquorum threshold 0.55]
    RWA[RWA — Reinforcement-Weighted Arbitration\nhourly EMA weight update from remediation_outcomes]
    BRL[BRL — Bayesian Reasoning Layer\nBeta prior + likelihood posterior — tier confidence 0–1]
    PSM[PSM — Predictive State Machine\nMarkov chain over tier transitions — next tier + dwell]
  end

  subgraph L4[Calibration Layer]
    ATCE[ATCE — Adaptive Threshold Calibration Engine\nhourly self-tuning from 30-day cache percentiles\n75th → T2  85th → T3  93rd → T4]
    CMPE[CMPE — Circadian Memory Pattern Engine\nhour-of-day SQL aggregate — proactive pre-freeze]
    CTRE[CTRE — Chronothermal Regression Engine\nper-hour OLS variance stability score 0–1]
  end

  subgraph L5[Remediation and Safety Layer]
    RVMS[RVMS — RSS Velocity Momentum Scorer\nvelocity boost 1×–2× on freeze composite score]
    GTS[GTS — Graduated Thaw Sequencer\nRSS-ascending SIGCONT — 2 s gap — RAM gate abort]
    XG[XPC Respawn Guard\nno-kill blocklist for launchd-managed services]
    ASZM[ASZM — Adaptive Safety Zone Mapping\ncriticality scoring — dynamic PROTECTED set]
    RAC[RAC — Reinforcement Action Coordinator\n30 s delayed outcome evaluation — success / failure]
  end

  subgraph L6[Diagnostics Layer]
    CDA[CDA — Causal Diagnostic Agent\nrule-based + optional ONNX softmax\nnormal / leak / compressor_collapse / cpu_collision]
  end

  BE --> SIE
  BE --> MMAF
  BE --> CEO
  BE --> AIP
  BE --> CDA

